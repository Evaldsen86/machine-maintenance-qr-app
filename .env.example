# Self-hosting example environment variables (NO REAL SECRETS)
# Copy to `.env` before running `docker compose`.

# ---------------------------
# Postgres
# ---------------------------
POSTGRES_USER=maskiina
POSTGRES_PASSWORD=change-me
POSTGRES_DB=maskiina

# Example DATABASE_URL used by backend (must match your backend stack)
# NOTE: Docker service name for Postgres is `postgres`.
DATABASE_URL=postgresql://maskiina:change-me@postgres:5432/maskiina

# ---------------------------
# Backend
# ---------------------------
NODE_ENV=production
BACKEND_PORT=3000

# Use a long random secret in production
JWT_SECRET=change-me-long-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Restrict CORS to your domain(s)
# Example: https://maskiina.your-company.local
CORS_ORIGIN=https://localhost

# ---------------------------
# Frontend (Vite build-time)
# ---------------------------
VITE_API_URL=http://localhost:3000/api

# ---------------------------
# Storage
# ---------------------------
# Choose `local` for host-mounted disk, or `minio` for S3-compatible object storage.
STORAGE_TYPE=minio

# Local disk upload directory inside the backend container
UPLOAD_DIR=/data/uploads

# MinIO (S3-compatible) settings
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minio-root-user
MINIO_ROOT_PASSWORD=minio-root-password

# Bucket for app uploads (documents/images/etc.)
MINIO_BUCKET=maskiina-files

# The backend often uses access/secret keys separately from root keys.
# You can set these to the same values initially, then rotate later.
MINIO_ACCESS_KEY=minio-root-user
MINIO_SECRET_KEY=minio-root-password

