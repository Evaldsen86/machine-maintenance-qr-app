# Backend environment example for Phase 6A foundation

NODE_ENV=development
PORT=3000

# PostgreSQL / Prisma
DATABASE_URL=postgresql://maskiina:change-me@localhost:5432/maskiina

# Auth
JWT_SECRET=change-me-long-random-secret
JWT_EXPIRES_IN=15m

# CORS (comma-separated list of allowed origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:8081

# Seed defaults
SEED_COMPANY_SLUG=default-company
SEED_COMPANY_NAME=Maskiina Internal
SEED_ADMIN_EMAIL=admin@maskiina.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Initial Admin

